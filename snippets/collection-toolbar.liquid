<div class="toolbar" id="collection-toolbar">
  <div class="toolbar__inner">
    <div class="toolbar__count-row">
      <span class="toolbar__count">{{ collection.products_count }} Results</span>
    </div>

    <div class="toolbar__controls">
      {%- comment -%} Wrapper anchor: filter panel sẽ absolute vào đây {%- endcomment -%}
      <div class="toolbar__filter-anchor">
        <button
          class="toolbar__filter-btn"
          id="filter-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="filter-panel">
          <img src="{{ 'component-filter.svg' | asset_url }}" alt="" width="16" height="16" loading="lazy">
          <span id="filter-btn-label">Show filters</span>
        </button>

        {%- comment -%} Filter panel chuyển vào đây, ngay dưới button {%- endcomment -%}
        {% render 'collection-filter' %}
      </div>

      <div class="toolbar__sort-block">
        <label class="toolbar__sort-label" for="sort-select">Sort by</label>
        <div class="toolbar__sort-wrap">
          <select class="toolbar__sort" id="sort-select" name="sort_by">
            {%- for option in collection.sort_options -%}
              <option
                value="{{ option.value }}"
                {% if option.value == collection.sort_by %}selected{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
          <span class="toolbar__sort-chevron" aria-hidden="true">
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
