{{ 'centered-text.css' | asset_url | stylesheet_tag }}

<section class="centered-text centered-text--{{ section.id }}">
  <div class="container">
    <div class="centered-text__inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="centered-text__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.content != blank -%}
        <div class="centered-text__content">{{ section.settings.content }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Centered text",
    "tag": "section",
    "class": "section-centered-text",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "WE KNOW EYES LIKE THE BACK OF OUR HAND"
      },
      {
        "type": "richtext",
        "id": "content",
        "label": "Content",
        "default": "<p>As your trusted optometrist and local glasses shop, we're here to make sure you see every beautiful detail life can offer.</p><p>Whether you want to explore our glasses frames, try on sunglasses, or book an eye test, we're here to help.</p>"
      }
    ],
    "presets": [
      {
        "name": "Centered text",
        "category": "Text"
      }
    ]
  }
{% endschema %}
