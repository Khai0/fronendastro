{{ 'header.css' | asset_url | stylesheet_tag }}

<header class="site-header header-background" role="banner">

  {%- comment -%} Hamburger — mobile only {%- endcomment -%}
  <button class="hamburger-btn" aria-label="Open menu" aria-expanded="false" id="hamburger-btn" type="button">
    <span class="hamburger-btn__bar"></span>
    <span class="hamburger-btn__bar"></span>
    <span class="hamburger-btn__bar"></span>
  </button>

  <div class="site-header__inner header-container">

    {%- comment -%} Cột 1: Logo {%- endcomment -%}
    <div class="site-header__left-group header-component-12">
      <div class="site-header__logo-wrap">
        <div class="site-header__logo">
          <a href="{{ routes.root_url }}" title="{{ shop.name }}">
            {% render 'icon', name: 'logo' %}
          </a>
        </div>
      </div>
    </div>

    {%- comment -%} Cột 2: Nav CENTER + Search row {%- endcomment -%}
    <div class="site-header__center">
      <nav class="site-header__nav-main" aria-label="Main navigation">
        {% render 'header__menu', menu_handle: section.settings.main_menu %}
      </nav>
    </div>

    {%- comment -%} Search button — same row as menu {%- endcomment -%}
    <div class="site-header__search site-header__button">
      <button @click="toggleFlyout('search')" type="button" class="search-btn" aria-label="Search">
        {% render 'icon', name: 'search' %}
      </button>
    </div>

    

  </div>
  {%- comment -%} Right: SIGN IN | BAG + BOOK AN EYE TEST {%- endcomment -%}
    <div class="site-header__right">
      <div class="site-header__utils">
        <ul class="utils-nav" role="list">
          <li>
            {%- if customer -%}
              <a class="utils-nav__link" href="{{ routes.account_url }}">{{ section.settings.account_label | default: 'MY ACCOUNT' }}</a>
            {%- else -%}
              <a class="utils-nav__link" href="{{ routes.account_login_url }}">{{ section.settings.signin_label | default: 'SIGN IN' }}</a>
            {%- endif -%}
          </li>
          <li class="utils-nav__cart-wrap">
            <a class="utils-nav__cart" href="{{ routes.cart_url }}" @click.prevent="toggleFlyout('minicart')" title="{{ 'layout.cart.title' | t }}" aria-label="Shopping bag">
              <span>BAG</span>
              <span class="cart-icon-wrap">
                {% render 'icon', name: 'cart' %}
                <div class="cart-count" v-if="cart && cart.item_count">${ cart.item_count }</div>
                <div class="minicart-button__dot" v-if="cart && cart.item_count"></div>
              </span>
            </a>
          </li>
        </ul>
      </div>

      <div class="site-header__cta header-button">
        <a class="cta-book" href="{{ section.settings.book_url | default: '/pages/book-an-eye-test' }}">
          {{ section.settings.book_label | default: 'BOOK AN EYE TEST' }}
        </a>
      </div>
    </div>

    {%- comment -%} Mobile right: Search + Bag {%- endcomment -%}
    <div class="site-header__mobile-actions">
      <button @click="toggleFlyout('search')" type="button" class="mobile-search-btn" aria-label="Search">
        {% render 'icon', name: 'search' %}
      </button>
      <a class="mobile-cart-btn" href="{{ routes.cart_url }}" @click.prevent="toggleFlyout('minicart')" title="{{ 'layout.cart.title' | t }}" aria-label="Shopping bag">
        {% render 'icon', name: 'cart' %}
        <small class="cart-count" v-if="cart && cart.item_count">${ cart.item_count }</small>
      </a>
    </div>
</header>

{%- comment -%} Mobile Menu Drawer {%- endcomment -%}
<div class="mobile-menu-overlay" id="mobile-menu-overlay" aria-hidden="true"></div>
<div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
  <div class="mobile-menu__header">
    <button class="mobile-menu__close" id="mobile-menu-close" aria-label="Close menu" type="button">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L17 17M17 1L1 17" stroke="#f7f6f3" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="mobile-menu__logo">{% render 'icon', name: 'logo' %}</div>
    <div class="site-header__search">
      <button @click="toggleFlyout('search')" type="button" class="search-btn" aria-label="Search">
        {% render 'icon', name: 'search' %}
      </button>
    </div>
  </div>

  <div class="mobile-menu__body">
    <div class="mobile-menu__signin">
      {%- if customer -%}
        <a href="{{ routes.account_url }}">{{ section.settings.account_label | default: 'MY ACCOUNT' }}</a>
      {%- else -%}
        <a href="{{ routes.account_login_url }}">{{ section.settings.signin_label | default: 'SIGN IN' }}</a>
      {%- endif -%}
    </div>

    <ul class="mobile-menu__nav" role="list">
      {%- for link in linklists[section.settings.main_menu].links -%}
        <li class="mobile-nav-item">
          <div class="mobile-nav-item__row">
            <a class="mobile-nav-item__link" href="{{ link.url }}">{{ link.title }}</a>
            {%- if link.links.size > 0 -%}
              <button class="mobile-nav-item__toggle" aria-expanded="false" type="button">
                <svg width="14" height="9" viewBox="0 0 18 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1.5L9 9.5L17 1.5" stroke="#222222" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            {%- endif -%}
          </div>
          {%- if link.links.size > 0 -%}
            <ul class="mobile-nav-item__dropdown" role="list">
              {%- for child_link in link.links -%}
                <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    <div class="mobile-menu__cta">
      <a class="mobile-cta-book" href="{{ section.settings.book_url | default: '/pages/book-an-eye-test' }}">
        {{ section.settings.book_label | default: 'BOOK AN EYE TEST' }}
      </a>
    </div>
  </div>
</div>

{% render 'header__search' %}
{% render 'header__minicart' %}
{% schema %}
{
"name": "Header",
"tag": "section",
"class": "section-header",
"settings": [
{
"type": "header",
"content": "Logo"
},
{
"type": "image_picker",
"id": "logo",
"label": "Logo"
},
{
  "type": "header",
  "content": "Navigation"
},
{
  "type": "link_list",
  "id": "main_menu",
  "label": "Menu",
  "default": "main-menu"
},
{
  "type": "header",
  "content": "User"
},
{
  "type": "text",
  "id": "signin_label",
  "label": "Sign in",
  "default": "SIGN IN"
},
{
  "type": "text",
  "id": "account_label",
  "label": "Account",
  "default": "MY ACCOUNT"
},
{
  "type": "header",
  "content": "CTA"
},
{
  "type": "text",
  "id": "book_label",
  "label": "Button label",
  "default": "BOOK AN EYE TEST"
},
{
  "type": "url",
  "id": "book_url",
  "label": "Button link"
}
],
"presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
