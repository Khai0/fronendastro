{%- if section.settings.attach_to != blank -%}
  {% assign parent_handle = section.settings.attach_to | handleize %}
  {{ 'megamenu-1.css' | asset_url | stylesheet_tag }}

  <transition name="megamenu">
    <div v-show="megamenuToggles['{{ parent_handle }}']" @mouseleave="closeAllMegamenus" parent-item="{{ parent_handle }}" class="megamenu megamenu--featured-2">
      <div class="container">
        <div class="megamenu-2-only">
          {% if section.settings.title != blank %}
            <p class="megamenu-2-title">{{ section.settings.title }}</p>
          {% endif %}

          <div class="megamenu-2-grid">
            {% for block in section.blocks %}
              {% if block.type == 'cta' %}
                <article class="megamenu-2-item" {{ block.shopify_attributes }}>
                  {% if block.settings.url != blank %}
                    <a href="{{ block.settings.url }}">
                  {% endif %}

                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 280 }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                      width="280"
                      height="100"
                    >
                  {% endif %}

                  {% if block.settings.title != blank %}
                    <p>{{ block.settings.title }}</p>
                  {% endif %}

                  {% if block.settings.url != blank %}
                    </a>
                  {% endif %}
                </article>
              {% endif %}
            {% endfor %}
          </div>

          {% if section.settings.view_all_url != blank and section.settings.view_all_label != blank %}
            <a class="megamenu-2-view-all" href="{{ section.settings.view_all_url }}">{{ section.settings.view_all_label }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </transition>
{%- endif -%}

{% schema %}
{
  "name": "Megamenu 2",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Popular Brands"
    },
    {
      "type": "text",
      "id": "attach_to",
      "label": "Parent menu item",
      "info": "This should be a unique menu item from the parent menu."
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "VIEW ALL BRANDS"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link"
    },
    {
      "type": "header",
      "content": "Blocks"
    },
    {
      "type": "paragraph",
      "content": "Add brand/logo blocks with optional links."
    }
  ],
  "blocks": [
    {
      "type": "cta",
      "name": "Block",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ]
}
{% endschema %}
